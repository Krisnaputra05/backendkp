{
	"info": {
		"_postman_id": "7d9e2a1b-3c4d-4e5f-a6b7-c8d9e0f1a2b3",
		"name": "POS Cashier System - Queue Based",
		"description": "Collection Otomatis untuk testing endpoint Kasir. Port sudah disesuaikan ke 3000.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. AUTH: Login Kasir",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var jsonData = pm.response.json();",
							"if (jsonData.success && jsonData.data.token) {",
							"    pm.environment.set(\"token\", jsonData.data.token);",
							"    console.log(\"Token otomatis di-update ke environment!\");",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"username\": \"kasir1\",\n    \"password\": \"password123\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/api/auth/login",
					"host": ["{{base_url}}"],
					"path": ["api", "auth", "login"]
				}
			}
		},
		{
			"name": "2. QUEUE: Buat Antrean Baru",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]
				},
				"method": "POST",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/sessions",
					"host": ["{{base_url}}"],
					"path": ["api", "sessions"]
				}
			}
		},
		{
			"name": "3. ORDER: Update Status (Dapur)",
			"request": {
				"auth": {
					"type": "bearer",
					"bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]
				},
				"method": "PUT",
				"body": {
					"mode": "raw",
					"raw": "{\"status\": \"processing\"}",
					"options": {"raw": {"language": "json"}}
				},
				"url": {
					"raw": "{{base_url}}/api/orders/PASTE_ORDER_ID_DISINI/status",
					"host": ["{{base_url}}"],
					"path": ["api", "orders", "PASTE_ORDER_ID_DISINI", "status"]
				}
			}
		}
	],
	"variable": [
		{ "key": "base_url", "value": "http://localhost:3000" },
		{ "key": "token", "value": "" }
	]
}
